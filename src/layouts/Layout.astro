---
import "@/styles/global.css";
import "@/styles/global.scss";

interface Props {
  title: string;
  showNav?: boolean;
}

const { title, showNav = true } = Astro.props;
const pathname = Astro.url.pathname;

const navLinks = [
  {
    href: "/",
    label: "Packages",
    active: pathname === "/" || pathname.startsWith("/packages"),
  },
  { href: "/tokens", label: "Tokens", active: pathname === "/tokens" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex" />
    <title>{title}</title>
  </head>
  <body class="bg-page text-ink min-h-screen font-sans antialiased">
    {
      showNav && (
        <header class="border-line bg-surface border-b">
          <div class="mx-auto flex max-w-4xl items-center justify-between px-4 py-3">
            <div class="flex items-center gap-6">
              <a href="/" class="flex items-center gap-2.5 font-semibold">
                <img src="/favicon.svg" alt="" class="size-6" />
                <span>Private npm registry</span>
              </a>
              <nav class="flex items-center gap-4">
                {navLinks.map((link) => (
                  <a
                    href={link.href}
                    aria-current={link.active ? "page" : undefined}
                    class:list={[
                      "text-sm transition-colors",
                      link.active
                        ? "text-ink font-medium"
                        : "text-ink-faint hover:text-ink",
                    ]}
                  >
                    {link.label}
                  </a>
                ))}
              </nav>
            </div>
            <form method="post" action="/api/logout">
              <button
                type="submit"
                class="text-ink-faint hover:text-ink cursor-pointer text-sm transition-colors"
              >
                Log out
              </button>
            </form>
          </div>
        </header>
      )
    }
    <main class="mx-auto max-w-4xl px-4 py-8">
      <slot />
    </main>
  </body>
</html>

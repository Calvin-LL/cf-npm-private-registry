---
import { env } from "cloudflare:workers";
import CreatePackageForm from "@/components/CreatePackageForm.vue";
import Layout from "@/layouts/Layout.astro";
import { formatDate } from "@/lib/client";
import { listPackages } from "@/lib/db";

const packages = await listPackages(env.DB);
---

<Layout title="Packages">
  <div class="flex flex-col gap-6">
    <h1 class="text-2xl font-bold">Packages</h1>
    <section class="border-line bg-surface rounded-lg border p-4 shadow-sm">
      <h2 class="text-ink-muted mb-3 text-sm font-semibold">New package</h2>
      <CreatePackageForm client:load />
    </section>
    <section class="border-line bg-surface rounded-lg border p-4 shadow-sm">
      {
        packages.length === 0 ? (
          <p class="text-ink-faint py-4 text-center text-sm">
            No packages yet. Create one above to get started.
          </p>
        ) : (
          <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
              <thead>
                <tr class="border-line text-ink-faint border-b text-xs uppercase">
                  <th class="py-2 pr-4 font-medium">Name</th>
                  <th class="py-2 pr-4 font-medium">Latest</th>
                  <th class="py-2 pr-4 font-medium">Versions</th>
                  <th class="py-2 pr-4 font-medium">Tokens</th>
                  <th class="py-2 font-medium">Created</th>
                </tr>
              </thead>
              <tbody>
                {packages.map((pkg) => (
                  <tr class="border-line-soft border-b last:border-b-0">
                    <td class="py-2.5 pr-4">
                      <a
                        href={`/packages/${pkg.name}`}
                        class="text-ink font-mono text-sm font-medium hover:underline"
                      >
                        {pkg.name}
                      </a>
                    </td>
                    <td class="text-ink-muted py-2.5 pr-4 font-mono">
                      {pkg.latest_version ?? "unpublished"}
                    </td>
                    <td class="text-ink-muted py-2.5 pr-4">
                      {pkg.version_count}
                    </td>
                    <td class="text-ink-muted py-2.5 pr-4">
                      {pkg.token_count}
                    </td>
                    <td class="text-ink-muted py-2.5">
                      {formatDate(pkg.created_at)}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )
      }
    </section>
  </div>
</Layout>

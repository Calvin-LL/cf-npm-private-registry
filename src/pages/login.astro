---
import Layout from "@/layouts/Layout.astro";

const hasError = Astro.url.searchParams.has("error");
---

<Layout title="Log in" showNav={false}>
  <div class="mx-auto mt-24 flex max-w-sm flex-col gap-6">
    <div class="flex flex-col items-center gap-2">
      <img src="/favicon.svg" alt="" class="size-12" />
      <h1 class="text-xl font-bold">Private npm registry</h1>
    </div>
    <form
      method="post"
      action="/api/login"
      class="border-line bg-surface flex flex-col gap-3 rounded-lg border p-6 shadow-sm"
    >
      <label class="flex flex-col gap-1.5">
        <span class="text-ink-muted text-sm font-medium">Admin password</span>
        <input
          type="password"
          name="password"
          required
          autofocus
          class="border-line-strong bg-surface focus:border-line-focus rounded-md border px-3 py-1.5 text-sm focus:outline-none"
        />
      </label>
      {
        hasError && (
          <p class="text-danger text-sm">Wrong password, try again.</p>
        )
      }
      <button
        type="submit"
        class="bg-primary text-primary-ink hover:bg-primary-hover cursor-pointer rounded-md px-4 py-2 text-sm font-medium transition-colors"
      >
        Log in
      </button>
    </form>
  </div>
</Layout>

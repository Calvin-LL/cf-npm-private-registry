---
import { env } from "cloudflare:workers";
import CopyButton from "@/components/CopyButton.vue";
import DeletePackageButton from "@/components/DeletePackageButton.vue";
import TokenManager from "@/components/TokenManager.vue";
import Layout from "@/layouts/Layout.astro";
import { formatDate } from "@/lib/client";
import {
  getDistTags,
  getPackageByName,
  listPackages,
  listTokensForPackage,
  listVersions,
} from "@/lib/db";

const name = Astro.params.name ?? "";
const pkg = await getPackageByName(env.DB, name);
if (!pkg) {
  return new Response("Package not found", { status: 404 });
}
const [tokens, versions, distTags, packages] = await Promise.all([
  listTokensForPackage(env.DB, pkg.id),
  listVersions(env.DB, pkg.id),
  getDistTags(env.DB, pkg.id),
  listPackages(env.DB),
]);
const packageOptions = packages.map(function toOption(row) {
  return { id: row.id, name: row.name };
});

const tagsByVersion = new Map<string, string[]>();
for (const [tag, version] of Object.entries(distTags)) {
  tagsByVersion.set(version, [...(tagsByVersion.get(version) ?? []), tag]);
}

const scope = pkg.name.split("/")[0];
const origin = Astro.url.origin;
const host = Astro.url.host;
const npmrcSnippet = `${scope}:registry=${origin}/\n//${host}/:_authToken=YOUR_TOKEN`;
const installCommand = `npm install ${pkg.name}`;
---

<Layout title={pkg.name}>
  <div class="flex flex-col gap-6">
    <div class="flex flex-col gap-1">
      <a href="/" class="text-ink-faint hover:text-ink text-sm"
        >&larr; All packages</a
      >
      <h1 class="font-mono text-2xl font-bold">{pkg.name}</h1>
    </div>

    <section
      class="border-line bg-surface flex flex-col gap-3 rounded-lg border p-4 shadow-sm"
    >
      <h2 class="text-ink-muted text-sm font-semibold">Use this package</h2>
      <p class="text-ink-muted text-sm">
        Add this to the <code class="bg-chip rounded px-1 font-mono text-xs"
          >.npmrc</code
        > of any project that installs or publishes it, with a token generated below:
      </p>
      <div class="flex items-start gap-2">
        <pre
          class="bg-code-bg text-code-ink grow overflow-x-auto rounded-md p-3 font-mono text-xs leading-relaxed">{npmrcSnippet}</pre>
        <CopyButton client:load text={npmrcSnippet} />
      </div>
      <div class="flex items-start gap-2">
        <pre
          class="bg-code-bg text-code-ink grow overflow-x-auto rounded-md p-3 font-mono text-xs leading-relaxed">{installCommand}</pre>
        <CopyButton client:load text={installCommand} />
      </div>
      <p class="text-ink-muted text-sm">
        Publishing works the same way: run{" "}
        <code class="bg-chip rounded px-1 font-mono text-xs">npm publish</code> in
        the package repo with a write token in its <code
          class="bg-chip rounded px-1 font-mono text-xs">.npmrc</code
        >.
      </p>
    </section>

    <section
      class="border-line bg-surface flex flex-col gap-3 rounded-lg border p-4 shadow-sm"
    >
      <div class="flex items-baseline justify-between">
        <h2 class="text-ink-muted text-sm font-semibold">Tokens</h2>
        <a href="/tokens" class="text-ink-faint hover:text-ink text-xs"
          >Manage all tokens &rarr;</a
        >
      </div>
      <TokenManager
        client:load
        packages={packageOptions}
        initialTokens={tokens}
        defaultSelectedIds={[pkg.id]}
        onlyPackageId={pkg.id}
      />
    </section>

    <section
      class="border-line bg-surface flex flex-col gap-3 rounded-lg border p-4 shadow-sm"
    >
      <h2 class="text-ink-muted text-sm font-semibold">Versions</h2>
      {
        versions.length === 0 ? (
          <p class="text-ink-faint text-sm">
            Nothing published yet. Generate a write token and run{" "}
            <code class="bg-chip rounded px-1 font-mono text-xs">
              npm publish
            </code>
            .
          </p>
        ) : (
          <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
              <thead>
                <tr class="border-line text-ink-faint border-b text-xs uppercase">
                  <th class="py-2 pr-4 font-medium">Version</th>
                  <th class="py-2 pr-4 font-medium">Tags</th>
                  <th class="py-2 font-medium">Published</th>
                </tr>
              </thead>
              <tbody>
                {versions
                  .slice()
                  .reverse()
                  .map((version) => (
                    <tr class="border-line-soft border-b last:border-b-0">
                      <td class="py-2 pr-4 font-mono">{version.version}</td>
                      <td class="py-2 pr-4">
                        {(tagsByVersion.get(version.version) ?? []).map(
                          (tag) => (
                            <span class="bg-chip text-chip-ink mr-1 rounded-full px-2 py-0.5 text-xs font-medium">
                              {tag}
                            </span>
                          ),
                        )}
                      </td>
                      <td class="text-ink-muted py-2">
                        {formatDate(version.published_at)}
                      </td>
                    </tr>
                  ))}
              </tbody>
            </table>
          </div>
        )
      }
    </section>

    <section
      class="border-danger-line bg-surface flex flex-col gap-3 rounded-lg border p-4 shadow-sm"
    >
      <h2 class="text-danger text-sm font-semibold">Danger zone</h2>
      <DeletePackageButton
        client:load
        packageId={pkg.id}
        packageName={pkg.name}
      />
    </section>
  </div>
</Layout>
